{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://uxr.local/schemas/mental-models.schema.json",
  "title": "Mental Models",
  "description": "Produced by the Mental Model agent (05b-mental-models.json). Assumption-vs-reality pairs, contradictions, and model shifts, framed as design gaps (not user error). Diagnoses root causes of friction.",
  "type": "object",
  "required": ["mental_models"],
  "additionalProperties": true,
  "properties": {
    "mental_models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["model_element", "user_assumption", "system_reality", "severity"],
        "additionalProperties": true,
        "properties": {
          "model_element": { "type": "string" },
          "user_assumption": { "type": "string", "minLength": 4 },
          "system_reality": { "type": "string", "minLength": 4 },
          "assumption_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["participant", "quote", "timestamp"],
              "additionalProperties": true,
              "properties": {
                "participant": { "type": "string" },
                "quote": { "type": "string" },
                "timestamp": { "type": "string" }
              }
            }
          },
          "participants_affected": { "type": "array", "items": { "type": "string" } },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "consequence": { "type": "string" },
          "product_implication": { "type": "string" }
        }
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "assumption_1": { "type": "string" },
          "assumption_2": { "type": "string" },
          "held_by_participants": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "model_shifts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "participant": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "trigger": { "type": "string" },
          "timestamp": { "type": "string" }
        }
      }
    }
  }
}
