{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://uxr.local/schemas/narrative.schema.json",
  "title": "Participant Narratives",
  "description": "Produced by the Participant Narrative agent (01b-participant-narratives.json). One case narrative per participant, preserving the individual story before synthesis. Every major claim cites a timestamp or quote.",
  "type": "object",
  "required": ["narratives"],
  "additionalProperties": true,
  "properties": {
    "narratives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["participant_id", "summary"],
        "additionalProperties": true,
        "properties": {
          "participant_id": { "type": "string" },
          "summary": { "type": "string", "minLength": 8, "description": "Story-arc narrative, not a list of themes." },
          "goals": { "type": "array", "items": { "type": "string" } },
          "expectations": { "type": "array", "items": { "type": "string" } },
          "breakdowns": { "type": "array", "items": { "type": "string" } },
          "decision_points": { "type": "array", "items": { "type": "string" } },
          "emotional_arc": { "type": "string" },
          "mental_model_signals": { "type": "array", "items": { "type": "string" } },
          "contradictions": { "type": "array", "items": { "type": "string" } },
          "citations": {
            "type": "array",
            "description": "Every major claim is grounded in a timestamp or quote.",
            "items": {
              "type": "object",
              "required": ["timestamp"],
              "additionalProperties": true,
              "properties": {
                "claim": { "type": "string" },
                "quote": { "type": "string" },
                "timestamp": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
